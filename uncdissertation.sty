\def\abbreviation#1#2#3{%
  \unc@addabbreviation{#2}{#3}
  \def#1{\relax}%
  \setbox0=\hbox{#3}%
  \ifdim\wd0>0pt\gdef#1{\abbreviationfinal{#1}{#2}\empty%
    #3 (#1)\xspace}
  \else\gdef#1{#2\protect\xspace}%
  \fi
  }

